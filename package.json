{
  "name": "team-task-manager",
  "version": "1.0.0",
  "description": "Team Task Manager - Full Stack Application",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "install-all": "npm install",
    "dev": "npm start --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "node server.js",
    "serve": "npx serve -s frontend/build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
