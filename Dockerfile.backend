# Build stage
FROM node:18-alpine AS backend-builder
WORKDIR /app/backend
COPY backend/package*.json ./
RUN npm ci

COPY backend ./
RUN npm run build 2>/dev/null || true

# Runtime stage for backend
FROM node:18-alpine AS backend
WORKDIR /app
COPY --from=backend-builder /app/backend ./

EXPOSE 5000
CMD ["npm", "start"]
